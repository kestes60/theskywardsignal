---
// This layout renders a single article. It receives the article's front-matter
// (title, dates, description) and shows the styled headline + metadata. The
// article's markdown body is passed in as page content via <slot />.
import Base from './Base.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  data: CollectionEntry<'blog'>['data'];
}

const { title, description, pubDate, updatedDate } = Astro.props.data;

// Format in UTC so the date shown always matches the date typed in front-matter,
// regardless of the timezone of the machine that builds the site.
const dateFmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });

const home = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
---

<Base title={title} description={description}>
  <article>
    <h1 class="article-title">{title}</h1>
    <p class="post-meta">
      <time datetime={pubDate.toISOString()}>{dateFmt(pubDate)}</time>
      {updatedDate && <span> · Updated {dateFmt(updatedDate)}</span>}
    </p>
    <div class="article-body">
      <slot />
    </div>
  </article>
  <a class="back-link" href={home}>← Back to all articles</a>
</Base>
